# LLM
GROQ_API_KEY=gsk_your_key_here

# MongoDB Atlas
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net
MONGODB_DB=security_copilot

# AWS Security Hub
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-southeast-1

# Redis (for Celery background workers)
REDIS_URL=redis://localhost:6379/0

# Email alerts (Resend)
RESEND_API_KEY=re_your_key_here
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=you@youremail.com

# Pinecone (vector DB)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX=security-copilot

# OpenAI (embeddings only — not for chat)
OPENAI_API_KEY=sk_your_key_here
